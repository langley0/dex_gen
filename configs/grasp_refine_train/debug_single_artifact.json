{
  "checkpoint": {
    "keep_last": 3,
    "output_dir": "outputs/grasp_refine_train/debug_single_artifact",
    "resume_from": null,
    "save_every": 100
  },
  "dataset": {
    "artifact_glob": null,
    "artifact_paths": [],
    "drop_invalid_samples": true,
    "normalizer_padding": 0.02,
